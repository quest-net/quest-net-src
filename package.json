{
  "name": "quest-net",
  "version": "1.0.0",
  "homepage": "https://quest-net.github.io",
  "private": true,
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@pixi/react": "^8.0.3",

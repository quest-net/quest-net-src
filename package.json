	"scripts": {
		"push:src": "git add . && git diff --cached --quiet && echo \"No changes to commit\" || (git commit -m \"chore(src): update\" && git push)",
		"predeploy": "npm run build",
		"deploy": "npx gh-pages -d build -r https://github.com/quest-net/quest-net.github.io.git",
		"deploy:beta": "npx gh-pages -d build -b beta -r https://github.com/quest-net/quest-net.github.io.git",
		"deploy:2.0": "npx gh-pages -d build -b 2.0 -r https://github.com/quest-net/quest-net.github.io.git",
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview"
	},
	"eslintConfig": {
		"extends": [
			"react-app",
			"react-app/jest"
		]
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"devDependencies": {

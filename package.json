    "deploy": "gh-pages -d build",
    "deploy:beta": "gh-pages -d build -b beta",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@iconify/json": "^2.2.396",
    "@iconify/tailwind4": "^1.0.6",
    "@pixi/devtools": "^2.0.1",
